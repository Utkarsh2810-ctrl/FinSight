# FinSight Frontend — Environment Variables
# Copy this file to .env.local and update values for your environment.
# These are baked in at BUILD TIME by Vite (not read at runtime).

# FastAPI backend base URL (no trailing slash)
VITE_API_URL=http://localhost:8000

# Spring Boot auth service base URL (no trailing slash)
VITE_AUTH_URL=http://localhost:8080
